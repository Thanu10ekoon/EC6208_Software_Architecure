{
  "info": {
    "name": "SmartFines API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8150"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginType\": \"ADMIN\",\n  \"identifier\": \"admin1\",\n  \"password\": \"Password01G\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Driver Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Driver\",\n  \"email\": \"john.driver@example.com\",\n  \"phone\": \"0771234567\",\n  \"nic\": \"123456789V\",\n  \"password\": \"Password01G\",\n  \"licenseNumber\": \"B1234567\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"address\": \"123 Main St\",\n  \"regionId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/driver-signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "driver-signup"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Officer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Officer\",\n  \"email\": \"jane.officer@example.com\",\n  \"phone\": \"0777654321\",\n  \"nic\": \"987654321V\",\n  \"password\": \"Password01G\",\n  \"officerCode\": \"OFF-1001\",\n  \"badgeNumber\": \"B-7788\",\n  \"stationName\": \"Central Station\",\n  \"regionId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/officers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "officers"
              ]
            }
          }
        },
        {
          "name": "List Officers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/officers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "officers"
              ]
            }
          }
        },
        {
          "name": "Get Admin Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "stats"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Fines",
      "item": [
        {
          "name": "Create Fine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driverNic\": \"123456789V\",\n  \"regionId\": 1\n,  \"vehicleNumber\": \"ABC-1234\",\n  \"violationDate\": \"2026-05-11\",\n  \"violationDetails\": \"Speeding over limit\",\n  \"violationPlace\": \"Colombo\",\n  \"fineAmount\": 2500.00,\n  \"licenseCollectionLocation\": \"Central Station\",\n  \"dueAt\": \"2026-06-01T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/fines",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "fines"
              ]
            }
          }
        },
        {
          "name": "List Driver Fines",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/fines/driver",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "fines",
                "driver"
              ]
            }
          }
        },
        {
          "name": "List Officer Fines",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/fines/officer",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "fines",
                "officer"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fineId\": 1,\n  \"paymentMethod\": \"ONLINE\",\n  \"transactionReference\": \"TXN-12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments"
              ]
            }
          }
        },
        {
          "name": "Upload Receipt",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/{{paymentId}}/receipt",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments",
                "{{paymentId}}",
                "receipt"
              ]
            }
          }
        },
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notifications"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Recollections",
      "item": [
        {
          "name": "Mark Recollected (Driver)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"License handed to station\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/recollections/driver/{{fineId}}/mark",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "recollections",
                "driver",
                "{{fineId}}",
                "mark"
              ]
            }
          }
        },
        {
          "name": "Confirm Recollected (Officer/Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Verified in system\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/recollections/{{fineId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "recollections",
                "{{fineId}}",
                "confirm"
              ]
            }
          }
        }
      ]
    }
  ]
}
